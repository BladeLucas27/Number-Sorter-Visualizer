<Window x:Class="SortingAlgorithms.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SortingAlgorithms"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="txtInput" Height="45" Margin="30,30,0,0" Text="10,5,3,8" VerticalAlignment="Top" FontSize="20" TextAlignment="Right" MaxLines="1" IsUndoEnabled="False" AutomationProperties.Name="txtScreen" HorizontalAlignment="Left" Width="443" CharacterCasing="Lower"/>
        <Button x:Name="btnStartSort" Content="Start Sorting" Margin="521,99,0,0" VerticalAlignment="Top" Click="ButtonStartSort_Click" Width="220" FontSize="20" RenderTransformOrigin="-1.093,-0.576" ClickMode="Press" HorizontalAlignment="Left"/>
        <Label x:Name="lblSize" Content="" HorizontalAlignment="Left" Margin="420,330,0,0" VerticalAlignment="Top" IsEnabled="False" FontSize="20" RenderTransformOrigin="0.961,0.006"/>
        <ComboBox x:Name="cbSortOptions" HorizontalAlignment="Left" Margin="521,30,0,0" VerticalAlignment="Top" Width="220" Height="45" FontSize="18" SelectedIndex="0"/>
        <TextBox x:Name="txtDisplay" Height="45" Margin="30,255,0,0" TextWrapping="Wrap" Text="10 | 5 | 3 | 8" VerticalAlignment="Top" FontSize="24" TextAlignment="Right" MaxLines="1" IsReadOnly="True" IsUndoEnabled="False" AutomationProperties.Name="txtScreen" HorizontalAlignment="Left" Width="691" IsEnabled="False" SelectionOpacity="5" FontWeight="Bold"/>
        <TextBox x:Name="txtFinished" HorizontalAlignment="Left" Margin="601,330,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Height="37" FontSize="24" TextAlignment="Right" IsEnabled="False" BorderBrush="{x:Null}" Foreground="#FF3CB72B"/>
    </Grid>
</Window>
